# ============================================================
# MoonMailer Pro Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values

NODE_ENV=production
PORT=3001
APP_URL=http://your-domain.com
API_URL=http://your-domain.com

# PostgreSQL
DATABASE_URL=postgresql://dbuser:dbpass@localhost:5432/powermm
DB_HOST=localhost
DB_PORT=5432
DB_NAME=powermm
DB_USER=your_db_user
DB_PASS=your_secure_db_password

# Redis
REDIS_URL=redis://localhost:6379

# JWT (GENERATE NEW SECRETS FOR PRODUCTION!)
# Use: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AES-256 Encryption Key (64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-hex-char-encryption-key-here

# Tracking Domain (used for open/click/unsubscribe URLs)
TRACKING_DOMAIN=http://your-domain.com

# SpamAssassin
SPAMASSASSIN_HOST=localhost
SPAMASSASSIN_PORT=783

# AI Advisor (optional)
ANTHROPIC_API_KEY=

# Default SMTP sender
SMTP_FROM_DEFAULT=noreply@your-domain.com

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800
